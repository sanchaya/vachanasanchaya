$('.vachanas_load').append("<%= escape_javascript(render(:partial => 'results')) %>");
var nextPage = <%= @results.next_page ? @results.next_page : 'null' %>;
if (nextPage) {
  var baseUrl = '<%= j vachanas_path(vachana: params[:vachana], search_type: params[:search_type], vachanakaara: params[:vachanakaara], start_letter: params[:start_letter]) %>';
  $('a.load-more-vachanas').attr('href', baseUrl + '&page=' + nextPage).show();
} else {
  $('a.load-more-vachanas').remove();
}