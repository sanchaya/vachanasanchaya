<%= render "layouts/search_box" %>

<div class="row">
  <div class="span12">
    <div class="ai-search-page" style="padding:20px;">
      <h2 style="border-bottom:2px solid #eee;padding-bottom:10px;">AI ವಚನ ಸಂಶೋಧನೆ</h2>
      <p style="color:#666;font-size:14px;">ವಚನ ಸಾಹಿತ್ಯದ ಬಗ್ಗೆ ನಿಮ್ಮ ಪ್ರಶ್ನೆಯನ್ನು ಕೇಳಿ. AI ನಿಮಗೆ ಸಂಶೋಧನಾ ಸಹಾಯವನ್ನು ಒದಗಿಸುತ್ತದೆ.</p>

      <p style="font-size:13px;color:#999;">💡 <strong>FREE ಮಾಡೆಲ್ಗಳು</strong> ಲಭ್ಯವಿವೆ — Groq ಮತ್ತು OpenRouter ನಲ್ಲಿ ಉಚಿತ ಮಾಡೆಲ್ಗಳನ್ನು ಬಳಸಬಹುದು. ಕೆಳಗೆ provider ಆಯ್ಕೆಮಾಡಿ.</p>

      <%= form_tag ai_search_vachanas_path, method: :get, id: "ai-search-form", style: "margin:20px 0;" do %>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;">
          <div>
            <label style="font-size:13px;color:#555;display:block;margin-bottom:4px;">Provider</label>
            <%= select_tag :provider,
              options_for_select(
                AiSearchService::PROVIDERS.map { |k, v| ["#{v[:name]} #{' (FREE!)' if %i[groq together google].include?(k)}", k] },
                @selected_provider
              ),
              style: "width:100%;height:36px;font-size:14px;padding:0 8px;border-radius:4px;border:1px solid #ccc;",
              id: "provider-select" %>
          </div>
          <div>
            <label style="font-size:13px;color:#555;display:block;margin-bottom:4px;">Model</label>
            <%= select_tag :model,
              options_for_select(
                AiSearchService.models_for(@selected_provider).map { |m| ["#{m.label} — #{m.pricing}", m.id] },
                @selected_model
              ),
              style: "width:100%;height:36px;font-size:14px;padding:0 8px;border-radius:4px;border:1px solid #ccc;",
              id: "model-select" %>
          </div>
        </div>

        <div style="margin-bottom:10px;">
          <label style="font-size:13px;color:#555;display:block;margin-bottom:4px;">API Key</label>
          <%= password_field_tag :api_key, nil, placeholder: @stored_key ? "•••••••••••• (ಕೀಲಿ ಈಗಾಗಲೇ ನಮೂದಿಸಲಾಗಿದೆ)" : "ನಿಮ್ಮ API ಕೀಲಿ", style: "width:100%;height:36px;font-size:14px;padding:0 10px;border-radius:4px;border:1px solid #ccc;box-sizing:border-box;", id: "api-key-input" %>
          <div id="key-hint" style="font-size:12px;color:#999;margin-top:4px;">
            <% case @selected_provider.to_s
               when "groq" %>
              <a href="https://console.groq.com/keys" target="_blank">Groq ನಲ್ಲಿ ಉಚಿತ API ಕೀಲಿ ಪಡೆಯಿರಿ</a> — FREE, ಯಾವುದೇ ಪಾವತಿ ಅಗತ್ಯವಿಲ್ಲ
            <% when "openrouter" %>
              <a href="https://openrouter.ai/keys" target="_blank">OpenRouter ನಲ್ಲಿ API ಕೀಲಿ ಪಡೆಯಿರಿ</a> — ಅನೇಕ ಉಚಿತ ಮಾಡೆಲ್ಗಳು ಲಭ್ಯ
            <% when "together" %>
              <a href="https://api.together.ai/settings/api-keys" target="_blank">Together AI ನಲ್ಲಿ ಉಚಿತ API ಕೀಲಿ ಪಡೆಯಿರಿ</a> — FREE, ಯಾವುದೇ ಪಾವತಿ ಅಗತ್ಯವಿಲ್ಲ
            <% when "google" %>
              <a href="https://aistudio.google.com/apikey" target="_blank">Google AI Studio ನಲ್ಲಿ ಉಚಿತ API ಕೀಲಿ ಪಡೆಯಿರಿ</a> — FREE (60 req/min)
            <% when "openai" %>
              <a href="https://platform.openai.com/api-keys" target="_blank">OpenAI API ಕೀಲಿ ಪಡೆಯಿರಿ</a>
            <% when "anthropic" %>
              <a href="https://console.anthropic.com/" target="_blank">Anthropic API ಕೀಲಿ ಪಡೆಯಿರಿ</a>
            <% end %>
          </div>
        </div>

        <div class="input-append" style="display:flex;gap:8px;width:100%;">
          <%= text_field_tag :q, @query, placeholder: "ಉದಾ: ದಾಸೋಹದ ಬಗ್ಗೆ ವಚನಗಳೇನು ಹೇಳುತ್ತವೆ?", style: "flex:1;height:40px;font-size:16px;padding:0 12px;border-radius:4px;border:1px solid #ccc;", id: "ai-search-input", autofocus: true %>
          <%= submit_tag "ಸಂಶೋಧಿಸಿ", class: "btn btn-primary", style: "height:42px;font-size:16px;", id: "ai-search-submit", data: { disable_with: "ಸಂಶೋಧಿಸುತ್ತಿದೆ..." } %>
        </div>
      <% end %>

      <div id="ai-loading" style="display:none;text-align:center;padding:40px;">
        <div class="loading-indicator" style="font-size:18px;">ಸಂಶೋಧಿಸುತ್ತಿದೆ... ದಯವಿಟ್ಟು ನಿರೀಕ್ಷಿಸಿ (ಇದು 30-60 ಸೆಕೆಂಡುಗಳನ್ನು ತೆಗೆದುಕೊಳ್ಳಬಹುದು)</div>
      </div>

      <% if @result.present? %>
        <div id="ai-result" style="margin-top:20px;">
          <% if @result[:error] %>
            <div class="ai-result-box" style="border-left-color:#e8a020;background:#fffbf0;">
              <h4 style="color:#8a6d00;">ಗಮನಿಸಿ</h4>
              <p style="margin:0;color:#664;font-size:14px;line-height:1.6;"><%= @result[:error] %></p>
            </div>
          <% else %>
            <% if @result[:search_summary] %>
              <p style="color:#666;font-size:13px;margin-bottom:15px;"><%= @result[:search_summary] %></p>
            <% end %>
            <% if @result[:provider] %>
              <p style="color:#999;font-size:12px;margin-bottom:10px;">Powered by <%= @result[:provider] %> / <%= @result[:model] %></p>
            <% end %>

            <% formatted = @result[:answer].to_s.dup
               formatted.gsub!(/\*\*(.+?)\*\*/, '<strong>\1</strong>')
               formatted.gsub!(/\n{2,}/, '</p><p>')
               formatted.prepend('<p>').concat('</p>') unless formatted.blank? %>
            <div class="ai-result-box">
              <h4>AI ವಿಶ್ಲೇಷಣೆ</h4>
              <div class="ai-answer">
                <%= formatted.html_safe %>
              </div>
            </div>

            <% if @result[:sources].present? %>
              <h4 style="margin-top:30px;margin-bottom:15px;">ಆಧಾರ ವಚನಗಳು (<%= @result[:sources].size %>)</h4>
              <div class="results_list_div">
                <% @result[:sources].each do |vachana| %>
                  <a href="#myModal_<%= vachana.id %>" role="button" data-toggle="modal">
                    <div class="box effect5 vachana-concord-box">
                      <div class="vachana-show-box">
                        <span><%= vachana.vachana.truncate(200, separator: ' ') %></span>
                      </div>
                      <div class="vachanakaara-name">
                        <span><%= vachana.vachanakaara.try(:name) %></span>
                      </div>
                    </div>
                  </a>

                  <div id="myModal_<%= vachana.id %>" class="modal hide fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true" style="text-align: left;">
                    <div class="modal-header">
                      <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
                      <h3 id="myModalLabel"><%= vachana.vachanakaara.try(:name) %></h3>
                    </div>
                    <div class="modal-body vachana-pop">
                      <p id="fe_text_<%= vachana.id %>"><%= vachana.vachana %></p>
                      <p><strong>ವಚನ ಸಂಖ್ಯೆ:</strong> <%= vachana.vachanaid %></p>
                      <%= render 'vachanas/related_vachanas_inline', vachana: vachana %>
                    </div>
                    <div class="modal-footer">
                      <button class="btn btn-listen" onclick="speakVachana('fe_text_<%= vachana.id %>')" title="ವಚನವನ್ನು ಕೇಳಿ">
                        <i class="fa fa-volume-up"></i>
                      </button>
                      <button class="btn btn-small" onclick="$(this).closest('.modal-footer').find('.feedback-inline').toggle()" title="ತಪ್ಪು ಮಾಹಿತಿ ವರದಿ ಮಾಡಿ">
                        <i class="fa fa-exclamation-triangle"></i>
                      </button>
                      <button class="btn" data-dismiss="modal" aria-hidden="true">ಮುಚ್ಚಿ</button>
                      <div class="feedback-inline" style="display:none;margin-top:8px;">
                        <%= render 'user_feedbacks/form', feedbackable_id: vachana.id, feedbackable_type: 'Vachana' %>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
var MODELS = <%= raw Hash[AiSearchService::PROVIDERS.map { |k, v| [k, v[:models].map { |m| [m.id, m.label, m.pricing] }] }].to_json %>;
var HINTS = {
  groq: '<a href="https://console.groq.com/keys" target="_blank">Groq ನಲ್ಲಿ ಉಚಿತ API ಕೀಲಿ ಪಡೆಯಿರಿ</a> — FREE, ಯಾವುದೇ ಪಾವತಿ ಅಗತ್ಯವಿಲ್ಲ',
  openrouter: '<a href="https://openrouter.ai/keys" target="_blank">OpenRouter ನಲ್ಲಿ API ಕೀಲಿ ಪಡೆಯಿರಿ</a> — ಅನೇಕ ಉಚಿತ ಮಾಡೆಲ್ಗಳು ಲಭ್ಯ',
  openai: '<a href="https://platform.openai.com/api-keys" target="_blank">OpenAI API ಕೀಲಿ ಪಡೆಯಿರಿ</a>',
  together: '<a href="https://api.together.ai/settings/api-keys" target="_blank">Together AI ನಲ್ಲಿ ಉಚಿತ API ಕೀಲಿ ಪಡೆಯಿರಿ</a> — FREE, ಯಾವುದೇ ಪಾವತಿ ಅಗತ್ಯವಿಲ್ಲ',
  google: '<a href="https://aistudio.google.com/apikey" target="_blank">Google AI Studio ನಲ್ಲಿ ಉಚಿತ API ಕೀಲಿ ಪಡೆಯಿರಿ</a> — FREE (60 req/min), ಯಾವುದೇ ಪಾವತಿ ಅಗತ್ಯವಿಲ್ಲ',
  anthropic: '<a href="https://console.anthropic.com/" target="_blank">Anthropic API ಕೀಲಿ ಪಡೆಯಿರಿ</a>'
};

$(function() {
  function updateModels(provider) {
    var models = MODELS[provider] || [];
    var $select = $('#model-select');
    $select.empty();
    $.each(models, function(i, m) {
      $select.append($('<option>').val(m[0]).text(m[1] + ' \u2014 ' + m[2]));
    });
    var hintEl = document.getElementById('key-hint');
    if (hintEl) {
      hintEl.innerHTML = HINTS[provider] || '';
    }
    var input = document.getElementById('api-key-input');
    if (input) {
      input.placeholder = provider === 'groq' ? 'gsk_... ನಿಮ್ಮ Groq API ಕೀಲಿ' :
                          provider === 'openrouter' ? 'sk-or-... ನಿಮ್ಮ OpenRouter API ಕೀಲಿ' :
                          provider === 'together' ? 'ನಿಮ್ಮ Together AI API ಕೀಲಿ' :
                          provider === 'google' ? 'ನಿಮ್ಮ Google AI API ಕೀಲಿ' :
                          provider === 'anthropic' ? 'sk-ant-... ನಿಮ್ಮ Anthropic API ಕೀಲಿ' :
                          'sk-... ನಿಮ್ಮ OpenAI API ಕೀಲಿ';
    }
  }

  $('#provider-select').on('change', function() {
    updateModels($(this).val());
  });

  $('#ai-search-form').on('submit', function() {
    $('#ai-result').hide();
    $('#ai-loading').show();
    $('#ai-search-submit').prop('disabled', true);
  });

  var clip = new ZeroClipboard($(".d_clip_button"));
});
</script>
