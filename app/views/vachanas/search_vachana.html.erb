<h1 style="display:none;">ಪೂರ್ಣಪಠ್ಯ ವಚನ ಹುಡುಕಾಟ</h1>
<div class="vachana-full-search"> 
  <%= form_tag search_vachana_vachanas_path, :method => :get do %>
  <%= text_field_tag :search, params[:search], style: "width: 40%; height: 50px;" %>
  <% end %>
</div>

<div class="results_list_div">
  <% @vachanas.each do |vachana| %>
  <a href="#myModal_<%= vachana.id %>" role="button"  data-toggle="modal" >
    <div class="box effect5">
     <div class="vachana-concord-box"> 
       <div class="vachana-show-box"> 
         <span>  <%=  vachana.vachana %> </span> 
       </div>
       --------------
       <div class= "vachanakaara-name"> 
         <span  >
           <%= "#{vachana.vachanakaara.name}" %> 
         </span>
       </div>
     </div>
   </div>
 </a>

 <div id="myModal_<%= vachana.id %>" class="modal hide fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
  <div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
    <h3 id="myModalLabel"> 
     <span class="vachanakaara-name">
      <%= "#{vachana.vachanakaara.name}" %>
    </span>
  </h3>
</div>
<div class="modal-body vachana-pop">
  <p id='fe_text_<%= vachana.id %>'> <%= raw vachana.vachana.gsub(/\n/, '<br />') %> 

  </p>
</div>
<div class="modal-footer">
  <div class='demo-area'>
    <div class='modal-footer-left'> 
       <% if vachana.reviewed? %>
      <i class="fa fa-pencil-square-o" aria-hidden="true" title="ಪರಿಶೀಲಿಸಲಾಗಿದೆ"></i>
      <% end %>
      ಸಮಗ್ರ ವಚನ ಸಂಪುಟ: <%= vachana.vachanakaara.reference_book_id ? vachana.vachanakaara.reference_book_id : "-" %>
      &nbsp;
      ವಚನದ ಸಂಖ್ಯೆ:  <%= vachana.vachanaid %>
    </div>
    <%= link_to(vachana.vachanakaara, class: "vachanakaara-icon-link") do %>
    <i class="fa fa-user"></i> 
    <% end %>
    <button class="btn btn-listen" onclick="speakVachana('fe_text_<%= vachana.id %>')" title="ವಚನವನ್ನು ಕೇಳಿ">
      <i class="fa fa-volume-up"></i>
    </button>
          <%= render "vachanas/bookmark_btn", vachana: vachana %>
          <%= render "vachanas/cite_btn", vachana: vachana %>
    <button class='btn d_clip_button' data-clipboard-target='fe_text_<%= vachana.id %>' data-clipboard-text='Default clipboard text from attribute' id='d_clip_button' title='Click me to copy to clipboard.'>
      <i class="fa fa-files-o fa-1x"></i>
    </button>
    <button class="btn btn-small" onclick="$(this).closest('.modal-footer').find('.feedback-inline').toggle()" title="ತಪ್ಪಿದ್ದರೆ ವರದಿ ಮಾಡಿ">
      <i class="fa fa-exclamation-triangle"></i>
    </button>
  </div>
  <div class="feedback-inline" style="display:none;margin-top:8px;">
    <%= render 'user_feedbacks/form', feedbackable_id: vachana.id, feedbackable_type: 'Vachana' %>
  </div>
</div>
<%= render 'vachanas/related_vachanas_inline', vachana: vachana %>
</div>


<% end %>
</div>
