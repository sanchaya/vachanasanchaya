      <span class="vowels_count">
        (<%= @vachanakaara_letter_counts[letter] || 0 %>)
      </span>
      <% end %>

      <% retroflex.each do |letter| %>
      <a href="<%= vachanakaara_path(@vachanakaara, start_letter: letter) %>" data-letter="<%= letter %>"><%= letter %></a>
      <span class="vowels_count">
        (<%= @vachanakaara_letter_counts[letter] || 0 %>)
      </span>
      <% end %>

      <% dentals.each do |letter| %>
      <a href="<%= vachanakaara_path(@vachanakaara, start_letter: letter) %>" data-letter="<%= letter %>"><%= letter %></a>
      <span class="vowels_count">
        (<%= @vachanakaara_letter_counts[letter] || 0 %>)
      </span>
      <% end %>

      <% labials.each do |letter| %>
      <a href="<%= vachanakaara_path(@vachanakaara, start_letter: letter) %>" data-letter="<%= letter %>"><%= letter %></a>
      <span class="vowels_count">
        (<%= @vachanakaara_letter_counts[letter] || 0 %>)
      </span>
      <% end %>

      <% unstructured_consonants.each do |letter| %>
      <a href="<%= vachanakaara_path(@vachanakaara, start_letter: letter) %>" data-letter="<%= letter %>"><%= letter %></a>
      <span class="vowels_count">
        (<%= @vachanakaara_letter_counts[letter] || 0 %>)
      </span>
      <% end %>
    </div>
  </div>

  <div class="span10">
    <div class="start_letter_vachana_list">
      <%= render "vachanakaara_vachana_list" %>
    </div>
    <%= render "layouts/google_add" %>
  </div>
</div>
