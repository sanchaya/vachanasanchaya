<% if params[:page] %>

$('.keywords_load').append("<%= escape_javascript(render(partial: 'results')) %>");
$('a.load-more-vachanas').attr('href',"<%= researches_path(start_letter: params[:start_letter], page: @keywords.next_page) %>");
<% unless @keywords.next_page %>
$('a.load-more-vachanas').remove();
<% end %>

<% else %>

$('.start_letter_keyword_list').html("<%= escape_javascript(render(:partial => 'keyword_list')) %>");

<% end %>