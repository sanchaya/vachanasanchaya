<h1 style="font-size:22px;color:#333;">ಬಳಕೆದಾರರ ಪ್ರತಿಕ್ರಿಯೆಗಳು</h1>

<div style="margin:15px 0;">
  <strong>ಫಿಲ್ಟರ್:</strong>
  <%= link_to 'ಎಲ್ಲಾ', feedbacks_path, class: "btn btn-small #{'btn-info' unless params[:status]}" %>
  <%= link_to 'ಬಾಕಿ ಉಳಿದಿವೆ', feedbacks_path(status: 'pending'), class: "btn btn-small #{'btn-info' if params[:status] == 'pending'}" %>
  <%= link_to 'ಪರಿಶೀಲಿಸಲಾಗಿದೆ', feedbacks_path(status: 'reviewed'), class: "btn btn-small #{'btn-info' if params[:status] == 'reviewed'}" %>
  <%= link_to 'ತಿರಸ್ಕರಿಸಲಾಗಿದೆ', feedbacks_path(status: 'dismissed'), class: "btn btn-small #{'btn-info' if params[:status] == 'dismissed'}" %>
</div>

<% if @feedbacks.any? %>
<table class="table table-striped table-bordered">
  <thead>
    <tr>
      <th>ದಿನಾಂಕ</th>
      <th>ಬಳಕೆದಾರ</th>
      <th>ವಿಷಯ</th>
      <th>ಪ್ರತಿಕ್ರಿಯೆ</th>
      <th>ಸ್ಥಿತಿ</th>
      <th>ಕ್ರಮ</th>
    </tr>
  </thead>
  <tbody>
    <% @feedbacks.each do |fb| %>
    <tr>
      <td style="white-space:nowrap;font-size:12px;"><%= fb.created_at.strftime('%d/%m/%Y %H:%M') %></td>
      <td style="font-size:13px;"><%= fb.user.try(:name) || fb.user.try(:email) || 'ಅಜ್ಞಾತ' %></td>
      <td style="font-size:13px;">
        <%= link_to fb.feedbackable_name, polymorphic_path(fb.feedbackable) if fb.feedbackable %>
        <br/><span style="font-size:11px;color:#888;"><%= fb.feedbackable_type %> #<%= fb.feedbackable_id %></span>
      </td>
      <td style="font-size:13px;max-width:400px;"><%= fb.comment %></td>
      <td>
        <span class="label <%= 'label-important' if fb.status == 'pending' %><%= 'label-success' if fb.status == 'reviewed' %><%= '' if fb.status == 'dismissed' %>">
          <%= fb.status %>
        </span>
      </td>
      <td style="white-space:nowrap;font-size:12px;">
        <% if fb.status != 'reviewed' %>
          <%= link_to '✅ ಪರಿಶೀಲಿಸಿದೆ', update_feedback_path(fb, status: 'reviewed', return_to: params[:status]), method: :post, class: 'btn btn-mini btn-success', style: 'font-size:11px;' %>
        <% end %>
        <% if fb.status != 'dismissed' %>
          <%= link_to '❌ ತಿರಸ್ಕರಿಸು', update_feedback_path(fb, status: 'dismissed', return_to: params[:status]), method: :post, class: 'btn btn-mini', style: 'font-size:11px;' %>
        <% end %>
        <% if fb.status != 'pending' %>
          <%= link_to '↩ ಮರಳಿ', update_feedback_path(fb, status: 'pending', return_to: params[:status]), method: :post, class: 'btn btn-mini', style: 'font-size:11px;' %>
        <% end %>
        <%= link_to '🗑 ಅಳಿಸು', destroy_feedback_path(fb, return_to: params[:status]), method: :post, class: 'btn btn-mini btn-danger', style: 'font-size:11px;', data: { confirm: 'ಖಚಿತವಾಗಿ ಅಳಿಸಬೇಕೇ?' } %>
      </td>
    </tr>
    <% end %>
  </tbody>
</table>

<%= will_paginate @feedbacks if @feedbacks.respond_to?(:total_pages) %>
<% else %>
<div class="alert alert-info" style="margin-top:15px;">ಯಾವುದೇ ಪ್ರತಿಕ್ರಿಯೆಗಳಿಲ್ಲ.</div>
<% end %>

<%= link_to '← ನಿರ್ವಹಣಾ ಸಲಕರಣೆಗಳು', admin_panel_path, class: 'btn' %>
