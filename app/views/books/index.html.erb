<h1 style="display:none;">ವಚನ ಪುಸ್ತಕಗಳು</h1>

<div style="text-align:center;padding:30px 0 20px;">
  <h1 style="font-size:28px;color:#333;margin-bottom:5px;">ವಚನ ಪುಸ್ತಕಗಳು</h1>
  <p style="font-size:14px;color:#888;margin-bottom:25px;">ಇಂಟರ್ನೆಟ್ ಆರ್ಕೈವ್‌ನ ಸರ್ವಂಟ್ಸ್ ಆಫ್ ನಾಲೆಡ್ಜ್ ಸಂಗ್ರಹದಲ್ಲಿ ಲಭ್ಯವಿರುವ ವಚನ ಸಾಹಿತ್ಯ ಪುಸ್ತಕಗಳು</p>
  <%= form_tag books_path, method: :get, style: "display:inline-block;" do %>
    <%= text_field_tag :search, @search_query, placeholder: "ಪುಸ್ತಕನ ಹೆಸರು, ಲೇಖಕ, ಅಥವಾ ಪದ...", style: "padding:10px 15px;font-size:16px;width:350px;border:2px solid #ddd;border-radius:4px;outline:none;" %>
    <%= submit_tag "ಹುಡುಕು", style: "padding:10px 25px;font-size:16px;background:#0066cc;color:white;border:none;border-radius:4px;cursor:pointer;" %>
  <% end %>
    <p style="font-size:13px;color:#888;margin-top:15px;">
      ಇನ್ನಷ್ಟು ವಚನ ಪುಸ್ತಕಗಳಿಗಾಗಿ
    <a href="https://archive.org/details/ServantsOfKnowledge?tab=collection&query=%E0%B2%B5%E0%B2%9A%E0%B2%A8" target="_blank" style="color:#0066cc;text-decoration:underline;">ಇಂಟರ್ನೆಟ್ ಆರ್ಕೈವ್ - ಸರ್ವಂಟ್ಸ್ ಆಫ್ ನಾಲೆಡ್ಜ್</a>
    ಗೆ ಭೇಟಿ ನೀಡಿ.
  </p>
  <p style="font-size:13px;color:#888;margin-top:10px;">
    ಹೆಚ್ಚಿನ ಕನ್ನಡ ಪುಸ್ತಕಗಳ ಮಾಹಿತಿಗಾಗಿ 
    <a href="https://pustaka.sanchaya.net" target="_blank" style="color:#0066cc;text-decoration:underline;display:inline-flex;align-items:center;gap:6px;">
      <img src="https://fonts.sanchaya.net/img/sanchaya-logo.png" alt="ಪುಸ್ತಕ ಸಂಚಯ" style="height:20px;width:auto;vertical-align:middle;">
      ಪುಸ್ತಕ ಸಂಚಯ
    </a>
    ಗೆ ಭೇಟಿ ನೀಡಿ.
  </p>
</div>

<% if @error.present? %>
  <div style="max-width:900px;margin:0 auto;padding:20px;text-align:center;color:#c00;background:#fef0f0;border:1px solid #fcc;border-radius:4px;">
    <%= @error %>
  </div>
<% end %>

<% if @search_query.present? && @books.blank? && @error.blank? %>
  <div style="max-width:900px;margin:0 auto;padding:40px 0;text-align:center;">
    <p style="font-size:16px;color:#888;">"<%= @search_query %>" ಫಲಿತಾಂಶಗಳು ಕಂಡುಬಂದಿಲ್ಲ</p>
  </div>
<% end %>

<% unless @books.blank? %>
  <div style="max-width:1100px;margin:0 auto;padding:0 15px;">
    <div style="font-size:14px;color:#666;margin-bottom:15px;">
      <%= @books.length %> ಪುಸ್ತಕಗಳು ಕಂಡುಬಂದವು
    </div>
    <div class="books-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:20px;">
      <% @books.each do |book| %>
        <div class="book-card" style="background:#fff;border:1px solid #e0e0e0;border-radius:8px;overflow:hidden;transition:box-shadow 0.2s,transform 0.2s;" onmouseover="this.style.boxShadow='0 8px 25px rgba(0,0,0,0.15)';this.style.transform='translateY(-2px)'" onmouseout="this.style.boxShadow='none';this.style.transform='none'">
          <a href="https://archive.org/details/<%= book['identifier'] %>" target="_blank" style="text-decoration:none;color:inherit;display:block;">
            <% if book['mediatype'] == 'texts' || book['mediatype'] == 'text' %>
              <div class="book-cover" style="height:240px;background:#f5f5f0;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;">
                <img src="https://archive.org/services/img/<%= book['identifier'] %>" alt="<%= book['title'] %>" style="max-width:100%;max-height:100%;object-fit:contain;" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
                <div class="book-placeholder" style="display:none;width:100%;height:100%;align-items:center;justify-content:center;background:linear-gradient(135deg,#f5f5f0 0%,#e8e6e3 100%);color:#888;font-size:14px;text-align:center;padding:20px;">
                  <i class="fa fa-book" style="font-size:48px;margin-bottom:10px;display:block;color:#bbb;"></i>
                  ಸಂಪುಟ
                </div>
              </div>
            <% else %>
              <div class="book-cover" style="height:240px;background:#f5f5f0;display:flex;align-items:center;justify-content:center;">
                <i class="fa fa-file-text-o" style="font-size:64px;color:#bbb;"></i>
              </div>
            <% end %>
            <div class="book-info" style="padding:15px;">
              <h3 style="font-size:15px;color:#333;margin:0 0 8px;line-height:1.3;height:40px;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">
                <%= book['title'].to_s.truncate(100) %>
              </h3>
              <% if book['creator'].present? %>
                <p style="font-size:13px;color:#666;margin:0 0 5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                  <%= Array(book['creator']).first.to_s.truncate(50) %>
                </p>
              <% end %>
              <% if book['date'].present? %>
                <p style="font-size:12px;color:#999;margin:0;">
                  <%= book['date'].to_s[0..3] %>
                </p>
              <% end %>
            </div>
          </a>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<% unless @search_query.present? %>
  <div style="max-width:900px;margin:40px auto 0;padding:0 15px;text-align:center;color:#888;">
    <p style="font-size:14px;">ಮೇಲಿನ ಹುಡುಕಾಟ ಪಟ್ಟಿಯಲ್ಲಿ ವಚನ, ವಚನಕಾರ, ಅಥವಾ ಸಂಪಾದಕ/ಪ್ರಕಾಶಕರ ಹೆಸರನು ನಮೂದಿಸಿ ಹುಡುಕಿ.</p>
    <p style="font-size:13px;margin-top:10px;">ಉದಾಹರಣೆ: <code style="background:#f5f5f0;padding:2px 6px;border-radius:3px;">ಅಲ್ಲಮ ಪ್ರಭು</code>, <code style="background:#f5f5f0;padding:2px 6px;border-radius:3px;">ವಚನ ಸಾಹಿತ್ಯ</code>, <code style="background:#f5f5f0;padding:2px 6px;border-radius:3px;">ಬಸವಣ್ಣ</code></p>
  </div>
<% end %>